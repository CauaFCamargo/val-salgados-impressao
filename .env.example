# Copie este arquivo para ".env" e ajuste os valores.

# Endereço da API (a mesma que o front usa).
API_URL="http://localhost:3000"

# Credenciais do painel (o agente loga pra poder ler os pedidos protegidos).
ADMIN_USER="val"
ADMIN_PASSWORD="val123"

# De quanto em quanto tempo checar por pedidos novos (em segundos).
POLL_INTERVAL="10"

# DRY_RUN=true → NÃO imprime de verdade, só mostra o cupom no terminal.
# Deixe "true" enquanto não tiver a impressora configurada.
DRY_RUN="true"

# Como o node-thermal-printer conversa com a impressora. Exemplos:
#   Windows (impressora compartilhada): "\\\\localhost\\NomeDaImpressora"
#   Rede (impressora com IP):           "tcp://192.168.0.99"
# Só é usado quando DRY_RUN=false.
IMPRESSORA_INTERFACE="tcp://192.168.0.99"
